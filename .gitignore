# =============================================================================
# Onboarding Hub - .gitignore
# =============================================================================

# ─── Environment ──────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
backend/.env

# ─── Dependencies ─────────────────────────────────────────────────────────
node_modules/
backend/node_modules/
frontend/node_modules/

# ─── Build output ─────────────────────────────────────────────────────────
dist/
backend/dist/
frontend/dist/
build/

# ─── Database (PostgreSQL data) ───────────────────────────────────────────
pg_*
PG_VERSION

# ─── Local data & logs ────────────────────────────────────────────────────
data/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Server configs (local environment) ───────────────────────────────────
seaweedfs-*.toml
seaweedfs-*.json

# ─── Internal session notes ───────────────────────────────────────────────
SESSION-*.md

# ─── SSL (local certs) ────────────────────────────────────────────────────
frontend/ssl/
*.pem
*.key

# ─── IDE / Editor ─────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.vscode/settings.json

# ─── OS ───────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ─── Docker ───────────────────────────────────────────────────────────────
docker-data/

# ─── PostgreSQL server config (local instance) ────────────────────────
postgresql.conf
postgresql.auto.conf
postmaster.opts
postmaster.pid
base/
global/
pg_*
PG_VERSION
