# =============================================================================
# Onboarding Hub - Environment Variables Template
# =============================================================================
# Copia este archivo a .env y completa los valores para tu entorno.
# ¡IMPORTANTE! Nunca subas el archivo .env con valores reales a repositorios.
# =============================================================================

# =============================================================================
# SEGURIDAD - JWT (REQUIRED)
# =============================================================================
# Clave secreta para firmar tokens JWT. Usa una cadena larga y aleatoria.
# Genera una nueva con: openssl rand -base64 64
# CAMBIAR EN PRODUCCIÓN
JWT_SECRET=change-me-to-a-secure-random-string-at-least-32-chars

# =============================================================================
# IA - MiMo API (Xiaomi) (REQUIRED)
# =============================================================================
# API Key para el servicio de Chat IA de Xiaomi
# Obtén tu API key en: https://api.xiaomimimo.com
# CAMBIAR EN PRODUCCIÓN
MIMO_API_KEY=your-mimo-api-key-here

# URL base del API de MiMo
MIMO_BASE_URL=https://api.xiaomimimo.com/v1

# Modelo de IA a utilizar
MIMO_MODEL=mimo-v2-omni

# =============================================================================
# BASE DE DATOS - PostgreSQL
# =============================================================================
# Configuración de conexión a PostgreSQL
# NOTA: El valor por defecto está configurado para Docker Compose local.
# Para producción, usa valores seguros y considera usar un servicio gestionado.
DATABASE_URL=postgresql://admin:KonektorDB2024!@postgres:5432/onboarding_hub

# =============================================================================
# CACHE - Redis
# =============================================================================
# URL de conexión a Redis (incluye número de base de datos)
REDIS_URL=redis://redis:6379/2

# Prefijo para claves de Redis (evita conflictos con otras apps)
REDIS_PREFIX=oh:

# =============================================================================
# ALMACENAMIENTO - SeaweedFS (S3-Compatible)
# =============================================================================
# SeaweedFS proporciona object storage compatible con S3.
# Configuración del cliente S3 para conectar con el filer de SeaweedFS.

# Hostname o IP del servicio SeaweedFS Filer
SEAWEEDFS_ENDPOINT=seaweedfs-filer

# Puerto S3 del SeaweedFS Filer
SEAWEEDFS_PORT=8333

# Access Key para autenticación S3
# Valor por defecto de SeaweedFS - CAMBIAR EN PRODUCCIÓN
SEAWEEDFS_ACCESS_KEY=minioadmin

# Secret Key para autenticación S3
# Valor por defecto de SeaweedFS - CAMBIAR EN PRODUCCIÓN
SEAWEEDFS_SECRET_KEY=minioadmin123

# Nombre del bucket donde se almacenarán los archivos
SEAWEEDFS_BUCKET=onboarding-hub

# Usar conexión segura (SSL/TLS)
SEAWEEDFS_USE_SSL=false

# URL pública para acceder a archivos desde el exterior
# Usar dominio/proxy real en producción
SEAWEEDFS_PUBLIC_URL=http://localhost:9006

# =============================================================================
# TRANSCRIPCIÓN - Whisper
# =============================================================================
# URL del servicio Whisper para transcripción de audio/video
# Puede ser localhost (si corre en host) o IP de otro contenedor
WHISPER_URL=http://host.docker.internal:8178

# =============================================================================
# FRONTEND Y CORS
# =============================================================================
# URL base del frontend (sin slash al final)
FRONTEND_URL=http://localhost:8090

# Orígenes permitidos para CORS (separados por comas)
# Incluye localhost para desarrollo y dominios de producción
CORS_ORIGIN=http://localhost:8090,https://onboarding.wagnersolutionsai.com

# =============================================================================
# CONFIGURACIÓN DEL SERVIDOR
# =============================================================================
# Puerto donde correrá la API
PORT=4001

# Entorno de ejecución (development | production)
NODE_ENV=development
